// firestore.rules
// ════════════════════════════════════════════════════
//  Firestore Security Rules
//  ارفع هذا الملف في Firebase Console > Firestore > Rules
// ════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    function isMember(chatData) {
      return isLoggedIn() &&
        request.auth.uid in chatData.members;
    }

    // ─── Users Collection ────────────────────────────
    match /users/{userId} {
      // Anyone logged in can read user profiles
      allow read: if isLoggedIn();
      // Only the owner can write their profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // No deletion allowed
    }

    // ─── Chats Collection ────────────────────────────
    match /chats/{chatId} {
      // Only members can read the chat
      allow read: if isMember(resource.data);

      // Logged in user can create a chat if they are in members list
      allow create: if isLoggedIn() &&
        request.auth.uid in request.resource.data.members;

      // Only members can update chat metadata
      allow update: if isMember(resource.data);

      // No deletion of chats
      allow delete: if false;

      // ─── Messages Sub-Collection ──────────────────
      match /messages/{messageId} {
        // Only chat members can read messages
        allow read: if isMember(get(/databases/$(database)/documents/chats/$(chatId)).data);

        // Only chat members can send messages
        allow create: if isLoggedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members &&
          request.resource.data.senderId == request.auth.uid;

        // Only the sender can update/delete their own messages
        allow update: if isLoggedIn() &&
          resource.data.senderId == request.auth.uid;

        allow delete: if isLoggedIn() &&
          resource.data.senderId == request.auth.uid;
      }
    }
  }
}
